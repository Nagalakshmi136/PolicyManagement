# ============================================================
# PolicyManagement BFF -- environment configuration template
# Copy to .env and fill in actual values.
# NEVER commit .env to source control.
# ============================================================

# -- SQL Server ---------------------------------------------------------------
# SA_PASSWORD must be >= 8 chars including upper, lower, digit, and symbol.
SA_PASSWORD=<YourStrong@Passw0rd>

# Full connection string used by the API.
# When running outside Docker, use localhost,1433.
# In Docker Compose, this is overridden via the api service environment block.
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=PolicyManagement;User Id=sa;Password=<YourStrong@Passw0rd>;TrustServerCertificate=True;

# -- Keycloak / JWT Bearer ----------------------------------------------------
# Admin credentials used by docker-compose to bootstrap the Keycloak admin user.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<YourAdminPassword>

# Keycloak Authority URL as seen by the API host.
# Local (no Docker): http://localhost:8180/realms/policy-mgmt
# Docker Compose:    overridden to http://keycloak:8080/realms/policy-mgmt in docker-compose.yml
Keycloak__Authority=http://localhost:8180/realms/policy-mgmt
Keycloak__Audience=policy-management-api

# -- Cache --------------------------------------------------------------------
Cache__SlidingExpirationSeconds=60
Cache__AbsoluteExpirationSeconds=300
Cache__ExpiringSoonDays=30

# -- Serilog (optional overrides) ---------------------------------------------
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning

# -- Seed users (development only -- defined in keycloak/realm-export.json) ---
# These credentials are pre-loaded into Keycloak on first start via realm-export.json.
# Username: reader-user  Password: Reader1234!  Role: policy-reader
# Username: admin-user   Password: Admin1234!   Role: policy-reader, policy-admin