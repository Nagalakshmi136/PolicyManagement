# ============================================================
# PolicyManagement BFF — environment configuration template
# Copy to .env and fill in actual values.
# NEVER commit .env to source control.
# ============================================================

# ── Database ────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=PolicyManagement;User Id=sa;Password=<YOUR_SA_PASSWORD>;TrustServerCertificate=True;

# ── Keycloak / JWT Bearer ────────────────────────────────────
Keycloak__Authority=http://localhost:8080/realms/policy-mgmt
Keycloak__Audience=policy-management-api

# ── Cache ────────────────────────────────────────────────────
Cache__SlidingExpirationSeconds=60
Cache__AbsoluteExpirationSeconds=300
Cache__ExpiringSoonDays=30

# ── Serilog (optional overrides) ────────────────────────────
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning
