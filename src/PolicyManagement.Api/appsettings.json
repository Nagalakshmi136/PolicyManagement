{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Keycloak": {
    "Authority": "",
    "Audience": ""
  },
  "Cache": {
    "SlidingExpirationSeconds": 300,
    "AbsoluteExpirationSeconds": 3600,
    "ExpiringSoonDays": 30
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact" }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "PolicyManagement.Api"
    }
  }
}

